    {
      "name": "Pre-request Script Examples",
      "item": [
        {
          "name": "Create Dynamic User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const randomNumber =\r",
                  "    Math.floor(Math.random() * 10000);\r",
                  "\r",
                  "const email =\r",
                  "    \"mohit\" +\r",
                  "    randomNumber +\r",
                  "    \"@example.com\";\r",
                  "\r",
                  "pm.environment.set(\r",
                  "    \"email\",\r",
                  "    email\r",
                  ");"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"name\": \"Mohit Waghmare\",\r\n    \"email\": \"{{email}}\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ]
            }
          },
          "response": []
